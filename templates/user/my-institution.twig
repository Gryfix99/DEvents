{# templates/user/institution-settings.twig — v13.0 (i18n ready) #}
<div id="settings-messages"></div>

{# Nagłówek sekcji generuje teraz powłoka panelu (panel.twig) z pozycji menu. #}

{# --- NAWIGACJA ZAKŁADKOWA --- #}
<div class="settings-tabs" role="tablist">
    <button type="button" class="tab-btn active" data-tab="tab-data" role="tab" aria-selected="true" aria-controls="tab-data">
        {{ __('DANE PODSTAWOWE', 'devents') }}
    </button>
    {% if not is_moderator %}
        <button type="button" class="tab-btn" data-tab="tab-network" role="tab" aria-selected="false" aria-controls="tab-network">
            {{ __('SIEĆ WSPÓŁPRACY', 'devents') }}
        </button>
        <button type="button" class="tab-btn" data-tab="tab-team" role="tab" aria-selected="false" aria-controls="tab-team">
            {{ __('MÓJ ZESPÓŁ', 'devents') }}
        </button>
    {% endif %}
    <button type="button" class="tab-btn" data-tab="tab-widget" role="tab" aria-selected="false" aria-controls="tab-widget">
        {{ __('WIDGET NA STRONĘ', 'devents') }}
    </button>
</div>

{# --- SEKCJA A: DANE PODSTAWOWE --- #}
<div id="tab-data" class="tab-content active" role="tabpanel">
    <div class="settings-card">
        {# Tytuł „Profil instytucji" jest już w nagłówku sekcji (.panel-page-header),
           więc nie powtarzamy go tutaj — zostaje tylko znacznik trybu moderatora. #}
        {% if is_moderator %}
            <div class="card-header-small">
                <span class="status-badge status-badge--info">{{ __('Tryb podglądu (Moderator)', 'devents') }}</span>
            </div>
        {% endif %}

        <form id="org-details-form" class="devents-form" method="post" enctype="multipart/form-data">
            <input type="hidden" name="action" value="devents_update_institution">
            
            {# Logo i Nazwa #}
            <div class="form-row logo-row-wrapper">
                <div class="logo-upload-section">
                    <div class="avatar-circle">
                        {% if org_data.logo_url %}
                            <img src="{{ org_data.logo_url|e }}" alt="{{ __('Logo', 'devents') }}" id="inst-logo-preview">
                        {% else %}
                            <span class="material-symbols-outlined" aria-hidden="true">domain</span>
                        {% endif %}
                    </div>
                    {% if not is_moderator %}
                        <div class="logo-actions">
                            <label for="logo_upload" class="btn btn--small btn--secondary pointer">{{ __('Zmień logo', 'devents') }}</label>
                            <input type="file" id="logo_upload" name="logo_upload" class="hidden-input" accept="image/*">
                            
                            {% if org_data.logo_url %}
                                <div class="delete-logo-option mt-5">
                                    <label class="text-link-danger pointer small-text">
                                        <input type="checkbox" name="delete_logo" value="true"> {{ __('Usuń logo', 'devents') }}
                                    </label>
                                </div>
                            {% endif %}
                        </div>
                    {% endif %}
                </div>

                <div class="form-group flex-grow-1">
                    <label class="form-label" for="inst-org-name">{{ __('Pełna nazwa instytucji / organizacji', 'devents') }}</label>
                    <input type="text" id="inst-org-name" name="org_name" value="{{ org_data.org_name|e }}" class="form-control check-empty" {{ is_moderator ? 'disabled' : '' }} required>
                </div>
            </div>

            {# Opis działalności #}
            <div class="form-group mt-20">
                <label class="form-label" for="inst-org-description">{{ __('Opis działalności', 'devents') }}</label>
                <textarea id="inst-org-description" name="org_description" class="form-textarea check-empty" rows="5" {{ is_moderator ? 'disabled' : '' }} placeholder="{{ __('Krótki opis czym zajmuje się Twoja instytucja...', 'devents') }}">{{ org_data.description|e }}</textarea>
            </div>

            {# Typ instytucji — tylko właściciel; zmienia dostęp do „Sieci jednostek" #}
            {% if not is_moderator %}
            <div class="form-group mt-20">
                <label class="form-label" for="inst-org-type">{{ __('Typ instytucji', 'devents') }}</label>
                <select id="inst-org-type" name="org_type" class="form-control">
                    <option value="unit" {{ org_data.type != 'master' ? 'selected' : '' }}>{{ __('Niezależny organizator (jednostka)', 'devents') }}</option>
                    <option value="master" {{ org_data.type == 'master' ? 'selected' : '' }}>{{ __('Instytucja kierująca innymi jednostkami (master)', 'devents') }}</option>
                </select>
                <span class="form-hint">{{ __('„Master" zarządza siecią jednostek i sam organizuje wydarzenia. „Jednostka" organizuje własne wydarzenia.', 'devents') }}</span>
            </div>
            {% endif %}

            {# Wizytówka Wideo PJM #}
            <div class="form-group pjm-highlight-box mt-20">
                <label class="form-label pjm-label-flex">
                    <span class="material-symbols-outlined" aria-hidden="true">sign_language</span>
                    {{ __('Wideo wizytówka w języku migowym (PJM)', 'devents') }}
                </label>
                <p class="pjm-field-desc">
                    {{ __('Dodaj link do filmu (YouTube/Vimeo) z Twoją wizytówką w PJM.', 'devents') }}
                </p>
                <div class="pjm-input-group flex-row gap-10">
                    <input type="url" name="pjm_video_link" id="pjm_video_link" value="{{ org_data.pjm_video_link|e }}" class="form-control check-empty flex-grow-1" {{ is_moderator ? 'disabled' : '' }} placeholder="https://www.youtube.com/watch?v=...">
                    {% if org_data.pjm_video_link %}
                        <button type="button" class="btn btn--outline js-preview-pjm-video" data-url="{{ org_data.pjm_video_link|e }}">
                            <span class="material-symbols-outlined" aria-hidden="true">play_circle</span> {{ __('Podgląd', 'devents') }}
                        </button>
                    {% endif %}
                </div>
                
                {# BANER ZAMÓWIENIA OPISU PJM #}
                {% if not org_data.pjm_video_link or org_data.pjm_video_link|trim == "" %}
                    <div class="pjm-promo-banner pjm-promo-banner--warning mt-10">
                        <div class="pjm-promo-banner__icon">
                            <span class="material-symbols-outlined" aria-hidden="true">info</span>
                        </div>
                        <div class="pjm-promo-banner__content">
                            <p class="pjm-promo-title">{{ __('Brak opisu działalności w PJM?', 'devents') }}</p>
                            <p>{{ __('Możesz go u nas zamówić! Przygotujemy tłumaczenie opisu (do 1800 znaków) na %spolski język migowy%s i napisami za %s300 zł%s.', 'devents')|replace({
                                '%spolski język migowy%s': '<strong>' ~ __('polski język migowy', 'devents') ~ '</strong>',
                                '%s300 zł%s': '<strong>' ~ __('300 zł', 'devents') ~ '</strong>'
                            })|raw }}</p>
                            <p>{{ __('Napisz do nas:', 'devents') }} <a href="mailto:janusz@januszmigowego.pl" class="pjm-promo-link">janusz@januszmigowego.pl</a></p>
                        </div>
                    </div>
                {% endif %}
            </div>

            {# NIP i Telefon #}
            <div class="form-row two-cols mt-20">
                <div class="form-group">
                    <label class="form-label" for="inst-org-nip">{{ __('NIP', 'devents') }}</label>
                    <input type="text" id="inst-org-nip" name="org_nip" value="{{ org_data.nip|e }}" class="form-control check-empty" {{ is_moderator ? 'disabled' : '' }} placeholder="{{ __('Np. 1234567890', 'devents') }}">
                </div>
                <div class="form-group">
                    <label class="form-label" for="inst-org-phone">{{ __('Telefon ogólny', 'devents') }}</label>
                    <input type="text" id="inst-org-phone" name="org_phone" value="{{ org_data.phone|e }}" class="form-control check-empty" {{ is_moderator ? 'disabled' : '' }} placeholder="{{ __('Np. +48 123 456 789', 'devents') }}">
                </div>
            </div>

            {# Email i WWW #}
            <div class="form-row two-cols">
                <div class="form-group">
                    <label class="form-label" for="inst-org-email">{{ __('E-mail ogólny', 'devents') }}</label>
                    <input type="email" id="inst-org-email" name="org_email" value="{{ org_data.email|e }}" class="form-control check-empty" {{ is_moderator ? 'disabled' : '' }} placeholder="kontakt@instytucja.pl">
                </div>
                <div class="form-group">
                    <label class="form-label" for="inst-org-website">{{ __('Strona WWW', 'devents') }}</label>
                    <input type="url" id="inst-org-website" name="org_website" value="{{ org_data.website|e }}" class="form-control check-empty" {{ is_moderator ? 'disabled' : '' }} placeholder="https://">
                </div>
            </div>

            {# Adres Siedziby #}
            <div class="address-section-card mt-20">
                <label class="form-label section-label bold mb-15">
                    <span class="material-symbols-outlined v-align-middle" aria-hidden="true">location_on</span> {{ __('Adres siedziby', 'devents') }}
                </label>

                {% set is_migrated = org_data.address_data.street is not empty %}
                {% if not is_migrated and org_data.address is not empty %}
                    <div class="alert alert--warning mb-15">
                        <strong>{{ __('Uwaga:', 'devents') }}</strong> {{ __('Wykryto starszy format adresu. Prosimy o przepisanie go do poniższych pól.', 'devents') }}
                    </div>
                {% endif %}

                <div class="form-grid address-grid-main mb-15">
                    <div class="form-group">
                        <small class="form-label">{{ __('Ulica', 'devents') }} <span class="form-required-field" aria-hidden="true">*</span></small>
                        <input type="text" name="street" value="{{ org_data.address_data.street|e }}" class="form-control check-empty" placeholder="{{ __('Ulica', 'devents') }}" aria-label="{{ __('Ulica', 'devents') }}" {{ is_moderator ? 'disabled' : '' }} required>
                    </div>
                    <div class="form-group">
                        <small class="form-label">{{ __('Nr budynku/lokalu', 'devents') }} <span class="form-required-field" aria-hidden="true">*</span></small>
                        <input type="text" name="house_number" value="{{ org_data.address_data.house_number|e }}" class="form-control check-empty" placeholder="{{ __('Nr', 'devents') }}" aria-label="{{ __('Nr budynku/lokalu', 'devents') }}" {{ is_moderator ? 'disabled' : '' }} required>
                    </div>
                </div>
                <div class="form-grid address-grid-geo">
                    <div class="form-group">
                        <small class="form-label">{{ __('Kod pocztowy', 'devents') }} <span class="form-required-field" aria-hidden="true">*</span></small>
                        <input type="text" name="zip_code" value="{{ org_data.address_data.zip_code|e }}" class="form-control check-empty" placeholder="00-000" aria-label="{{ __('Kod pocztowy', 'devents') }}" {{ is_moderator ? 'disabled' : '' }} required>
                    </div>
                    <div class="form-group">
                        <small class="form-label">{{ __('Miasto', 'devents') }} <span class="form-required-field" aria-hidden="true">*</span></small>
                        <input type="text" name="city" value="{{ org_data.address_data.city|e }}" class="form-control check-empty" placeholder="{{ __('Miasto', 'devents') }}" aria-label="{{ __('Miasto', 'devents') }}" {{ is_moderator ? 'disabled' : '' }} required>
                    </div>
                </div>
            </div>

            {# Koordynator Dostępności #}
            <div class="coordinator-section-static mt-30">
                <h4 class="form-section-title mb-15">{{ __('Dane administratora instytucji (właściciel)', 'devents') }}</h4>
                <div class="form-row two-cols">
                    <div class="form-group">
                        <label class="form-label" for="inst-coordinator-first-name">{{ __('Imię', 'devents') }}</label>
                        <input type="text" id="inst-coordinator-first-name" name="coordinator_first_name" value="{{ org_data.coordinator.first_name|e }}" class="form-control" {{ is_moderator ? 'disabled' : '' }}>
                    </div>
                    <div class="form-group">
                        <label class="form-label" for="inst-coordinator-last-name">{{ __('Nazwisko', 'devents') }}</label>
                        <input type="text" id="inst-coordinator-last-name" name="coordinator_last_name" value="{{ org_data.coordinator.last_name|e }}" class="form-control" {{ is_moderator ? 'disabled' : '' }}>
                    </div>
                </div>
                <div class="form-row two-cols">
                    <div class="form-group">
                        <label class="form-label" for="inst-coordinator-email">{{ __('E-mail', 'devents') }}</label>
                        <input type="email" id="inst-coordinator-email" name="coordinator_email" value="{{ org_data.coordinator.email|e }}" class="form-control" {{ is_moderator ? 'disabled' : '' }}>
                    </div>
                    <div class="form-group">
                        <label class="form-label" for="inst-coordinator-phone">{{ __('Telefon', 'devents') }}</label>
                        <input type="text" id="inst-coordinator-phone" name="coordinator_phone" value="{{ org_data.coordinator.phone|e }}" class="form-control" {{ is_moderator ? 'disabled' : '' }}>
                    </div>
                </div>
            </div>

            {% if not is_moderator %}
                <div class="form-actions-footer mt-30 text-right">
                    <input type="hidden" name="_wpnonce" value="{{ details_nonce }}">
                    <button type="submit" class="btn btn--primary btn-lg">
                        <span class="material-symbols-outlined" aria-hidden="true">save</span> {{ __('Zapisz zmiany', 'devents') }}
                    </button>
                </div>
            {% endif %}
        </form>
    </div>

    {# --- SEKCJA PLAKATU DOSTĘPNOŚCI --- #}
    {% if not is_moderator %}
    <div class="settings-card mt-30">
        <div class="card-header-small">
            <h3><span class="material-symbols-outlined v-align-middle" aria-hidden="true">print</span> {{ __('Promuj dostępność w swojej placówce', 'devents') }}</h3>
        </div>
        <div class="poster-generator-section mt-15">
            <p>{{ __('Pobierz i wydrukuj plakat z kodem QR, aby informować odwiedzających o Twoich dostępnych wydarzeniach na platformie devents.', 'devents') }}</p>
            <button type="button" id="devents-generate-poster-btn" class="btn btn--secondary mt-15" data-nonce="{{ org_action_nonce }}">
                <span class="material-symbols-outlined v-align-middle" aria-hidden="true">print</span> {{ __('Wygeneruj plakat (PDF)', 'devents') }}
            </button>
        </div>
    </div>
    {% endif %}
</div>

{# --- SEKCJA B: SIEĆ WSPÓŁPRACY --- #}
<div id="tab-network" class="tab-content" style="display: none;" role="tabpanel">
    <div class="settings-card">
        <div class="card-header-small">
            <h3><span class="material-symbols-outlined v-align-middle" aria-hidden="true">hub</span> {{ __('Sieć współpracy', 'devents') }}</h3>
        </div>
        <div class="network-status-container">
            {% if master_org %}
                <div class="network-active-card">
                    <span class="material-symbols-outlined network-icon-large" aria-hidden="true">verified</span>
                    <div class="network-info-text">
                        <strong>{{ __('Podłączono do:', 'devents') }} {{ master_org.display_name|e }}</strong>
                        <p>{{ __('Twoje wydarzenia są raportowane do administratora sieci.', 'devents') }}</p>
                    </div>
                    <button type="button" class="btn btn--small btn--danger btn--text action-leave-org">{{ __('Odłącz się', 'devents') }}</button>
                </div>
            {% elseif pending_master_org %}
                <div class="network-pending-card">
                    <span class="material-symbols-outlined network-icon-large warning" aria-hidden="true">hourglass_top</span>
                    <div class="network-info-text">
                        <strong>{{ __('Oczekiwanie na akceptację', 'devents') }}</strong>
                        <p>{{ __('Wysłano prośbę do:', 'devents') }} {{ pending_master_org.display_name|e }}</p>
                    </div>
                </div>
            {% else %}
                <form id="join-org-form" class="join-network-form">
                    <label for="org_code" class="form-label">{{ __('Masz kod z Instytucji nadrzędnej?', 'devents') }}</label>
                    <div class="input-inline-group flex-row gap-10">
                        <input type="text" id="org_code" name="org_code" class="form-control" placeholder="{{ __('Np. WAW-8822', 'devents') }}" required>
                        <button type="submit" class="btn btn--secondary">{{ __('Połącz', 'devents') }}</button>
                    </div>
                </form>
            {% endif %}
        </div>
    </div>
</div>

{# --- SEKCJA C: MÓJ ZESPÓŁ --- #}
<div id="tab-team" class="tab-content" style="display: none;" role="tabpanel">
    <div class="settings-card">
        <div class="card-header-small">
            <h3>{{ __('Zarządzanie Zespołem', 'devents') }}</h3>
            <p class="section-subtitle">{{ __('Dodaj pracowników, aby pomogli Ci zarządzać ofertami.', 'devents') }}</p>
        </div>
        
        <div class="invite-staff-box mb-30">
            <form id="invite-team-form" class="devents-form">
                <input type="hidden" id="fallback_team_nonce" value="{{ team_action_nonce }}">
                <div class="form-row two-cols">
                    <div class="form-group">
                        <label class="form-label" for="inst-team-first-name">{{ __('Imię pracownika', 'devents') }}</label>
                        <input type="text" id="inst-team-first-name" name="first_name" class="form-control" required placeholder="{{ __('np. Anna', 'devents') }}">
                    </div>
                    <div class="form-group">
                        <label class="form-label" for="inst-team-email">{{ __('E-mail służbowy', 'devents') }}</label>
                        <input type="email" id="inst-team-email" name="email" class="form-control" required placeholder="anna@instytucja.pl">
                    </div>
                </div>

                <div class="role-selection-container mb-20">
                    <p class="form-label">{{ __('Uprawnienia:', 'devents') }}</p>
                    <div class="role-cards-grid">
                        <label class="role-radio-card mt-10">
                            <input type="radio" name="is_admin" value="1">
                            <div class="role-card-content">
                                <strong>{{ __('Administrator', 'devents') }}</strong>
                                <small>{{ __('Pełny dostęp do danych', 'devents') }}</small>
                            </div>
                        </label>
                        <label class="role-radio-card mt-10">
                            <input type="radio" name="is_admin" value="0" checked>
                            <div class="role-card-content">
                                <strong>{{ __('Moderator', 'devents') }}</strong>
                                <small>{{ __('Tylko zarządzanie ofertami', 'devents') }}</small>
                            </div>
                        </label>
                    </div>
                </div>
                <button type="submit" class="btn btn--secondary btn--full-width">
                    <span class="material-symbols-outlined" aria-hidden="true">mail</span> {{ __('Wyślij zaproszenie', 'devents') }}
                </button>
            </form>
        </div>

        <div class="team-lists-wrapper">
            {% if pending_invitations is not empty %}
                <div class="team-section mb-20">
                    <h4 class="team-section-title warning">{{ __('Oczekujące zaproszenia', 'devents') }}</h4>
                    {% for invite in pending_invitations %}
                        <div class="member-row pending">
                            <div class="member-meta">
                                <strong>{{ invite.email|e }}</strong>
                                <small>{{ __('Rola:', 'devents') }} {{ invite.role == 'organizer' ? __('Admin', 'devents') : __('Moderator', 'devents') }}</small>
                            </div>
                            <button type="button" class="btn--icon btn--danger action-cancel-invite" data-id="{{ invite.id }}" aria-label="{{ __('Anuluj zaproszenie', 'devents') }}"><span class="material-symbols-outlined" aria-hidden="true">close</span></button>
                        </div>
                    {% endfor %}
                </div>
            {% endif %}

            <div class="team-section">
                <h4 class="team-section-title">{{ __('Aktywni członkowie', 'devents') }}</h4>
                {% if team_members is not empty %}
                    {% for member in team_members %}
                        <div class="member-row">
                            <div class="member-info-flex">
                                <div class="member-avatar-init">
                                    {{ member.first_name|first|upper ?: member.display_name|first|upper }}
                                </div>
                                <div class="member-meta">
                                    <strong>{{ member.first_name|e ?: member.display_name|e }}</strong>
                                    <small>{{ member.user_email|e }}</small>
                                </div>
                            </div>
                            <button type="button" class="btn--icon btn--danger action-remove-member" data-id="{{ member.ID }}" aria-label="{{ __('Usuń członka zespołu', 'devents') }}"><span class="material-symbols-outlined" aria-hidden="true">person_remove</span></button>
                        </div>
                    {% endfor %}
                {% else %}
                    <p class="empty-list-msg">{{ __('Brak innych członków zespołu.', 'devents') }}</p>
                {% endif %}
            </div>
        </div>
    </div>
</div>

{# --- SEKCJA: WIDGET / PUBLICZNE API NA WŁASNĄ STRONĘ --- #}
<div id="tab-widget" class="tab-content" style="display: none;" role="tabpanel">
    <div class="settings-card">
        <div class="card-header-small">
            <h3 style="margin:0 0 4px;"><span class="material-symbols-outlined" aria-hidden="true" style="vertical-align:middle;">code</span> {{ __('Widget wydarzeń na Twoją stronę', 'devents') }}</h3>
            <p class="section-subtitle" style="margin:0;color:var(--text-secondary);">{{ __('Osadź listę swoich nadchodzących wydarzeń na własnej stronie — wystarczy wkleić poniższy kod.', 'devents') }}</p>
        </div>

        {% if institution_id %}
            {# Podgląd na żywo — pokazuje realnie to, co zobaczą na swojej stronie. #}
            <div class="form-group" style="margin-top:18px;">
                <label class="form-label">{{ __('Podgląd na żywo', 'devents') }}</label>
                <div id="dv-widget-preview" data-institution="{{ institution_id }}" data-api="{{ api_url }}"
                     aria-live="polite"
                     style="border:1px dashed var(--border-primary);border-radius:10px;padding:16px;background:var(--bg-hover);min-height:120px;">
                    <p style="color:var(--text-secondary);margin:0;">{{ __('Wczytywanie podglądu…', 'devents') }}</p>
                </div>
                <p style="font-size:.82rem;color:var(--text-secondary);margin:8px 0 0;">{{ __('Dokładnie tak wyświetlą się Twoje nadchodzące wydarzenia po wklejeniu kodu.', 'devents') }}</p>
            </div>

            <div class="form-group" style="margin-top:18px;">
                <label class="form-label">{{ __('Twój identyfikator instytucji (ID)', 'devents') }}</label>
                <div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap;">
                    <input type="text" class="form-control" readonly value="{{ institution_id }}" style="max-width:140px;font-weight:700;" onclick="this.select()" aria-label="{{ __('Identyfikator instytucji', 'devents') }}">
                    <span style="font-size:.85rem;color:var(--text-secondary);">{{ __('To Twój publiczny numer w API — nie jest tajny i nie wymaga klucza.', 'devents') }}</span>
                </div>
            </div>

            <div class="form-group" style="margin-top:18px;">
                <label class="form-label" for="dv-widget-embed">{{ __('Kod do wklejenia (HTML)', 'devents') }}</label>
                <textarea id="dv-widget-embed" class="form-control" readonly rows="3" onclick="this.select()" style="font-family:monospace;font-size:.85rem;line-height:1.5;"><script src="{{ widget_src }}" data-institution="{{ institution_id }}" data-limit="6"></script></textarea>
                <button type="button" class="btn btn--secondary btn--small dv-copy-btn" data-copy-target="#dv-widget-embed" style="margin-top:8px;">
                    <span class="material-symbols-outlined" aria-hidden="true" style="vertical-align:middle;font-size:18px;">content_copy</span> {{ __('Kopiuj kod', 'devents') }}
                </button>
                <p style="font-size:.82rem;color:var(--text-secondary);margin:10px 0 0;">{{ __('Wklej w miejscu, gdzie mają pojawić się wydarzenia. Opcjonalne parametry: data-limit (ile wydarzeń), data-city (filtr miasta).', 'devents') }}</p>
            </div>

            <div class="form-group" style="margin-top:18px;">
                <label class="form-label" for="dv-widget-api">{{ __('Adres API (do własnych integracji / CMS)', 'devents') }}</label>
                <input type="text" id="dv-widget-api" class="form-control" readonly value="{{ api_url }}?institution={{ institution_id }}&limit=12" onclick="this.select()" style="font-family:monospace;font-size:.85rem;" aria-label="{{ __('Adres API', 'devents') }}">
                <button type="button" class="btn btn--secondary btn--small dv-copy-btn" data-copy-target="#dv-widget-api" style="margin-top:8px;">
                    <span class="material-symbols-outlined" aria-hidden="true" style="vertical-align:middle;font-size:18px;">content_copy</span> {{ __('Kopiuj adres API', 'devents') }}
                </button>
                <p style="font-size:.82rem;color:var(--text-secondary);margin:10px 0 0;">{{ __('Zwraca JSON z Twoimi nadchodzącymi wydarzeniami (tylko odczyt, bez logowania, CORS dozwolony).', 'devents') }}</p>
            </div>
        {% else %}
            <p class="empty-list-msg" style="margin-top:18px;">{{ __('Widget będzie dostępny po utworzeniu profilu instytucji.', 'devents') }}</p>
        {% endif %}
    </div>
</div>

<script>
(function () {
    document.querySelectorAll('.dv-copy-btn').forEach(function (btn) {
        btn.addEventListener('click', function () {
            var el = document.querySelector(btn.getAttribute('data-copy-target'));
            if (!el) return;
            el.focus(); el.select();
            var done = function () {
                var orig = btn.innerHTML;
                btn.innerHTML = '<span class="material-symbols-outlined" aria-hidden="true" style="vertical-align:middle;font-size:18px;">check</span> Skopiowano!';
                setTimeout(function () { btn.innerHTML = orig; }, 1800);
            };
            if (navigator.clipboard && navigator.clipboard.writeText) {
                navigator.clipboard.writeText(el.value).then(done).catch(function () { try { document.execCommand('copy'); done(); } catch (e) {} });
            } else {
                try { document.execCommand('copy'); done(); } catch (e) {}
            }
        });
    });

    // --- Podgląd widgetu na żywo (samodzielny; wierny devents-widget.js) ---
    var pv = document.getElementById('dv-widget-preview');
    if (pv) {
        var inst = pv.getAttribute('data-institution');
        var apiBase = pv.getAttribute('data-api');
        var api = apiBase + '?limit=4' + (inst ? '&institution=' + encodeURIComponent(inst) : '');
        var esc = function (v) { var d = document.createElement('div'); d.textContent = (v == null ? '' : v); return d.innerHTML; };
        fetch(api).then(function (r) { return r.json(); }).then(function (j) {
            var evs = (j && j.events) || [];
            if (!evs.length) { pv.innerHTML = '<p style="color:var(--text-secondary);margin:0;">Brak nadchodzących wydarzeń do pokazania.</p>'; return; }
            var html = '<div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:12px;">';
            html += evs.map(function (e) {
                var d = new Date(e.start);
                var ds = isNaN(d.getTime()) ? '' : d.toLocaleDateString('pl-PL', { day: '2-digit', month: 'short' });
                var meta = [ds, e.city ? esc(e.city) : '', e.free ? 'Bezpłatne' : ''].filter(Boolean).join(' · ');
                var bg = e.image ? ('background-image:url(\'' + String(e.image).replace(/['"\\]/g, '') + '\');background-size:cover;background-position:center;') : 'background:var(--border-primary);';
                return '<a href="' + esc(e.url) + '" target="_blank" rel="noopener" style="border:1px solid var(--border-primary);border-radius:10px;overflow:hidden;text-decoration:none;color:var(--text-primary);background:var(--bg-secondary);display:flex;flex-direction:column;">' +
                    '<span style="aspect-ratio:16/9;' + bg + '" aria-hidden="true"></span>' +
                    '<span style="padding:10px;display:flex;flex-direction:column;gap:4px;"><span style="font-weight:600;font-size:.9rem;line-height:1.3;">' + esc(e.title) + '</span><span style="font-size:.78rem;color:var(--text-secondary);">' + meta + '</span></span></a>';
            }).join('');
            html += '</div>';
            pv.innerHTML = html;
        }).catch(function () {
            pv.innerHTML = '<p style="color:var(--text-secondary);margin:0;">Nie udało się wczytać podglądu.</p>';
        });
    }
})();
</script>

