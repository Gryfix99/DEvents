<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>DEvents – Dostępne Wydarzenia</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
        href="https://fonts.googleapis.com/css2?family=Dosis:wght@400;500;600;700;800&display=swap"
        rel="stylesheet"
    />
    <link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,1,0"
    />

    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>

    <style>
        :root{
            --bg:#2b2d30;
            --p:#00857C;
            --pd:#00332f;
            --p2:#f8b334;
            --a:#956F28;
            --a2:#c49035;
            --s:#1a1a1c;
            --white:#ffffff;
            --radius-xl:8mm;
            --radius-lg:5mm;
            --radius-md:3mm;
            --shadow-xl:0 10px 40px rgba(0,0,0,.45);
            --safe-padding-x:12mm;
        }

        *,*::before,*::after{ box-sizing:border-box; }

        html,body{
            margin:0;
            padding:0;
            min-height:100vh;
            background:var(--bg);
            display:flex;
            align-items:center;
            justify-content:center;
            font-family:'Dosis',sans-serif;
            overflow-x:hidden;
            text-rendering:optimizeLegibility;
            -webkit-font-smoothing:antialiased;
            -moz-osx-font-smoothing:grayscale;
        }

        body{ padding:20px; }

        /* =========================
           LOADER
        ========================== */
        #pdf-loader{
            position:fixed;
            inset:0;
            z-index:99999;
            background:rgba(43,45,48,.96);
            display:flex;
            flex-direction:column;
            align-items:center;
            justify-content:center;
            color:#fff;
        }

        .spinner{
            width:58px;
            height:58px;
            border-radius:50%;
            border:5px solid rgba(255,255,255,.12);
            border-top-color:var(--p2);
            animation:spin 1s linear infinite;
            margin-bottom:24px;
        }

        @keyframes spin{ to{ transform:rotate(360deg); } }

        #loader-text{
            font-size:24px;
            font-weight:700;
            letter-spacing:.3px;
            text-align:center;
        }

        /* =========================
           POSTER SHELL
        ========================== */
        #poster-content{
            width:210mm;
            height:296.5mm;
            position:relative;
            overflow:hidden;
            display:flex;
            flex-direction:column;
            background:#fff;
            color:var(--s);
            isolation:isolate;
            contain:layout;
            box-shadow:var(--shadow-xl);
        }

        /* =========================
           TOP BAR
        ========================== */
        .poster-top-bar{
            height:4mm;
            flex-shrink:0;
            background:linear-gradient(90deg,var(--pd),var(--p),var(--a2));
        }

        /* =========================
           HERO
        ========================== */
        .poster-hero{
            position:relative;
            display:flex;
            flex-direction:column;
            justify-content:flex-end;
            min-height:92mm;
            padding:8mm var(--safe-padding-x) 8mm;
            background:linear-gradient(135deg,var(--pd) 0%,#004d47 55%,#005a52 100%);
            overflow:hidden;
            flex-shrink:0;
        }

        .poster-deco-q{
            position:absolute;
            bottom:-18mm;
            right:-4mm;
            font-size:220pt;
            font-weight:800;
            line-height:1;
            color:rgba(255,255,255,.04);
            pointer-events:none;
            user-select:none;
            font-family:'Dosis',sans-serif;
        }

        .poster-deco-ring-a{
            position:absolute;
            width:64mm;
            height:64mm;
            top:-24mm;
            left:-12mm;
            border-radius:50%;
            border:10mm solid rgba(0,176,158,.06);
        }

        .poster-deco-ring-b{
            position:absolute;
            width:38mm;
            height:38mm;
            top:10mm;
            left:20mm;
            border-radius:50%;
            border:5mm solid rgba(248,179,52,.06);
        }

        .hero-pre-label{
            position:relative;
            z-index:2;
            display:inline-flex;
            align-items:center;
            gap:2mm;
            padding:1.5mm 3.5mm;
            border-radius:999px;
            background:rgba(248,179,52,.15);
            border:.3mm solid rgba(248,179,52,.35);
            color:var(--p2);
            font-size:8.5pt;
            font-weight:700;
            letter-spacing:.8px;
            text-transform:uppercase;
            margin-bottom:4mm;
            width:fit-content;
        }

        .hero-pre-label .material-symbols-outlined{
            font-size:12pt !important;
        }

        .poster-headline-q{
            position:relative;
            z-index:2;
            margin:0 0 6mm;
            font-size:36pt;
            line-height:1.15; /* Powiększony odstęp między wierszami */
            letter-spacing:-1px;
            font-weight:800;
            color:#fff;
            text-transform:uppercase;
            text-shadow:0 4px 12px rgba(0,0,0,.3);
        }

        .poster-headline-q .hl{
            color:var(--p2);
            display:block;
            line-height: 1.1; 
            padding-top: 1.5mm; /* Dodatkowy odstęp z góry */
        }

        .poster-headline-q .sm{
            font-size:20pt;
            letter-spacing:-.2px;
            color:rgba(255,255,255,.8);
            display:block;
            margin-top:3mm;
            text-transform:none;
            font-weight:600;
        }

        .hero-icon-strip{
            position:relative;
            z-index:2;
            display:flex;
            align-items:center;
            gap:0;
            margin-top:auto;
        }

        .hero-icon{
            width:11mm;
            height:11mm;
            flex-shrink:0;
            border-radius:50%;
            display:flex;
            align-items:center;
            justify-content:center;
            background:rgba(255,255,255,.10);
            border:.3mm solid rgba(255,255,255,.18);
        }

        .hero-icon .material-symbols-outlined{
            font-size:14pt !important;
            color:#fff;
        }

        .hero-icon-conn{
            width:3mm;
            height:.5mm;
            background:rgba(255,255,255,.18);
        }

        .hero-icon-label{
            margin-left:4mm;
            font-size:7.5pt;
            font-weight:700;
            letter-spacing:1.5px;
            text-transform:uppercase;
            color:rgba(255,255,255,.6);
        }

        /* =========================
           LOWER SECTION
        ========================== */
        .poster-lower{
            position:relative;
            flex:1 1 auto;
            min-height:0;
            display:flex;
            flex-direction:column;
            justify-content: space-between; /* Równomierne rozłożenie elementów */
            padding:6mm var(--safe-padding-x) 6mm;
            background:linear-gradient(to bottom,rgba(255,255,255,1),rgba(250,250,250,1));
        }

        .poster-lower-dots{
            position:absolute;
            inset:0;
            pointer-events:none;
            background-image:radial-gradient(circle,rgba(0,0,0,.03) 1px,transparent 1px);
            background-size:6mm 6mm;
        }

        .answer-hook{
            position:relative;
            z-index:1;
            flex-shrink:0;
            margin:10mm 0 2mm;
        }

        .answer-hook-label{
            font-size:8pt;
            font-weight:700;
            text-transform:uppercase;
            letter-spacing:2px;
            color:var(--p);
            margin:0 0 1mm;
        }

        .answer-hook-headline{
            margin:0;
            font-size:18pt;
            font-weight:800;
            line-height:1.1;
            color:var(--s);
            letter-spacing:-.4px;
        }

        .answer-hook-headline em{
            font-style:normal;
            color:var(--p);
        }

        /* =========================
           FEATURE GRID
        ========================== */
        .feature-grid{
            position:relative;
            z-index:1;
            flex-shrink:0;
            display:grid;
            grid-template-columns:1fr 1fr;
            gap:2.5mm;
            margin:10mm 0 0;
        }

        .feature-card{
            display:flex;
            align-items:center;
            gap:3mm;
            padding:3.5mm 3.5mm;
            border-radius:var(--radius-md);
            background:#fff;
            border:.4mm solid rgba(0,133,124,.15);
            box-shadow:0 2px 8px rgba(0,0,0,.04);
        }

        .feature-card.wide{
            grid-column:1 / -1;
            background:linear-gradient(90deg,rgba(0,51,47,.05),rgba(0,51,47,.02));
            border-color:rgba(0,133,124,.25);
        }

        .feature-icon-wrap{
            width:10mm;
            height:10mm;
            flex-shrink:0;
            border-radius:50%;
            background:rgba(0,133,124,.1);
            display:flex;
            align-items:center;
            justify-content:center;
        }

        .feature-card.wide .feature-icon-wrap{
            background:rgba(0,51,47,.12);
        }

        .feature-icon-wrap .material-symbols-outlined{
            font-size:13pt !important;
            color:var(--p);
        }

        .feature-card.wide .feature-icon-wrap .material-symbols-outlined{
            color:var(--pd);
        }

        .feature-text strong{
            display:block;
            font-size:10pt;
            font-weight:800;
            color:var(--s);
            line-height:1.15;
        }

        .feature-text span{
            display:block;
            font-size:7.5pt;
            font-weight:600;
            color:#777;
            line-height:1.3;
            margin-top:.5mm;
        }

        .feature-card.wide .feature-text strong{
            color:var(--pd);
        }

        /* =========================
           SEPARATOR
        ========================== */
        .poster-separator{
            position:relative;
            z-index:1;
            flex-shrink:0;
            display:flex;
            align-items:center;
            gap:3mm;
            margin: auto 0 4mm; /* To automatycznie spycha blok CTA do dołu */
        }

        .poster-separator-line{
            flex:1;
            height:.5mm;
            background:linear-gradient(90deg,transparent,#dcdcdc,transparent);
        }

        .poster-separator-gem{
            width:4mm;
            height:4mm;
            flex-shrink:0;
            border-radius:1mm;
            transform:rotate(45deg);
            background:linear-gradient(135deg,var(--p),var(--a));
            box-shadow:0 0 10px rgba(149,111,40,.3);
        }

        /* =========================
           CTA BOX
        ========================== */
        .cta-block{
            position:relative;
            z-index:1;
            flex:0 0 auto; /* Koniec z rozciąganiem ramki na wysokość */
            display:flex;
            align-items:center;
            gap:5mm;
            padding:4mm 5mm;
            border-radius:var(--radius-md);
            background:linear-gradient(135deg,var(--pd) 0%,#004d47 100%);
            overflow:hidden;
        }

        .cta-block::before{
            content:'';
            position:absolute;
            width:40mm;
            height:40mm;
            top:-16mm;
            right:30mm;
            border-radius:50%;
            border:7mm solid rgba(255,255,255,.04);
            pointer-events:none;
        }

        .cta-qr-wrap{
            flex-shrink:0;
            width:26mm;
            height:26mm;
            background:#fff;
            border-radius:2mm;
            padding:1.5mm;
            display:flex;
            align-items:center;
            justify-content:center;
        }

        #general-qr-code{
            width:100%;
            height:100%;
        }

        #general-qr-code canvas,
        #general-qr-code img{
            width:100% !important;
            height:100% !important;
            display:block;
        }

        .cta-text{
            flex:1;
            min-width:0;
        }

        .cta-text-label{
            font-size:7pt;
            font-weight:700;
            text-transform:uppercase;
            letter-spacing:1.8px;
            color:rgba(255,255,255,.55);
            margin:0 0 1.5mm;
        }

        .cta-text-url{
            font-size:22pt; /* Zmniejszone aby logo się zmieściło */
            font-weight:800;
            line-height:1;
            color:#fff;
            margin:0 0 1.5mm;
            overflow-wrap:anywhere;
        }

        .cta-text-url span{
            color:var(--p2);
            font-size:1.25em;
        }

        .cta-text-sub{
            font-size:7.5pt;
            font-weight:600;
            color:rgba(255,255,255,.55);
            line-height:1.3;
        }

        /* Logo wewnątrz CTA */
        .cta-logo-wrap {
            position: relative;
            z-index: 2;
            margin-left: auto; /* Dopycha logo do prawej krawędzi */
            padding-left: 3mm;
            display: flex;
            align-items: center;
            justify-content: flex-end;
        }

        #poster-devents-logo-wrapper {
            height: 18mm; /* Idealna wysokość wewnątrz ramki CTA */
            width: max-content;
            overflow: hidden;
            display: block;
        }

        #poster-devents-logo {
            height: 24mm; /* +6mm przestrzeni aby -3mm margines uciął rogi */
            margin: -3mm; /* Fizyczne ucięcie 3mm białego światła z logo */
            display: block;
            max-width: none;
        }

        /* =========================
           BOTTOM BAR
        ========================== */
        .poster-bottom-bar{
            height:4mm;
            flex-shrink:0;
            background:linear-gradient(90deg,var(--a),var(--p));
        }

        /* =========================
           PRINT
        ========================== */
        @media print{
            html,body{ background:#fff; }
            #poster-content{ box-shadow:none !important; }
            *{
                -webkit-print-color-adjust:exact !important;
                print-color-adjust:exact !important;
            }
        }
    </style>
</head>

<body>

    <div id="pdf-loader">
        <div class="spinner" id="spinner"></div>
        <div id="loader-text">Generowanie plakatu DEvents...</div>
    </div>

    <div id="poster-content">

        <!-- TOP BAR -->
        <div class="poster-top-bar"></div>

        <!-- HERO -->
        <section class="poster-hero">

            <div class="poster-deco-q">?</div>
            <div class="poster-deco-ring-a"></div>
            <div class="poster-deco-ring-b"></div>

            <!-- Pre-label -->
            <div class="hero-pre-label">
                <span class="material-symbols-outlined" aria-hidden="true">
                    travel_explore
                </span>
                portal dostępnych wydarzeń w Polsce
            </div>

            <!-- Main question -->
            <h1 class="poster-headline-q">
                Szukasz
                <span class="hl">dostępnych<br>wydarzeń?</span>
                <span class="sm">Mamy dokładnie to, czego szukasz.</span>
            </h1>

            <!-- Icon strip -->
            <div
                class="hero-icon-strip"
                role="img"
                aria-label="Ikony standardów dostępności"
            >
                <div class="hero-icon">
                    <span class="material-symbols-outlined" aria-hidden="true">sign_language</span>
                </div>
                <div class="hero-icon-conn"></div>
                <div class="hero-icon">
                    <span class="material-symbols-outlined" aria-hidden="true">subtitles</span>
                </div>
                <div class="hero-icon-conn"></div>
                <div class="hero-icon">
                    <span class="material-symbols-outlined" aria-hidden="true">self_improvement</span>
                </div>
                <div class="hero-icon-conn"></div>
                <div class="hero-icon">
                    <span class="material-symbols-outlined" aria-hidden="true">audio_description</span>
                </div>
                <div class="hero-icon-conn"></div>
                <div class="hero-icon">
                    <span class="material-symbols-outlined" aria-hidden="true">accessibility</span>
                </div>
                <span class="hero-icon-label">Standard Dostępności</span>
            </div>

        </section>

        <!-- LOWER (no wave) -->
        <section class="poster-lower">

            <div class="poster-lower-dots"></div>

            <!-- Hook -->
            <div class="answer-hook">
                <p class="answer-hook-label">znajdziesz tu między innymi</p>
                <h2 class="answer-hook-headline">
                    Wydarzenia dostosowane<br>
                    do <em>Twoich potrzeb</em>
                </h2>
            </div>

            <!-- Feature grid -->
            <div class="feature-grid">

                <div class="feature-card">
                    <div class="feature-icon-wrap">
                        <span class="material-symbols-outlined" aria-hidden="true">sign_language</span>
                    </div>
                    <div class="feature-text">
                        <strong>W języku migowym</strong>
                        <span>Prowadzone lub tłumaczone w&nbsp;PJM</span>
                    </div>
                </div>

                <div class="feature-card">
                    <div class="feature-icon-wrap">
                        <span class="material-symbols-outlined" aria-hidden="true">subtitles</span>
                    </div>
                    <div class="feature-text">
                        <strong>Z napisami</strong>
                        <span>Napisy na żywo lub dla niesłyszących</span>
                    </div>
                </div>

                <div class="feature-card">
                    <div class="feature-icon-wrap">
                        <span class="material-symbols-outlined" aria-hidden="true">self_improvement</span>
                    </div>
                    <div class="feature-text">
                        <strong>Z pokojem wyciszenia</strong>
                        <span>Strefa spokoju i&nbsp;odpoczynku</span>
                    </div>
                </div>

                <div class="feature-card">
                    <div class="feature-icon-wrap">
                        <span class="material-symbols-outlined" aria-hidden="true">audio_description</span>
                    </div>
                    <div class="feature-text">
                        <strong>Z audiodeskrypcją</strong>
                        <span>Opis słowny treści wizualnych</span>
                    </div>
                </div>

                <div class="feature-card wide">
                    <div class="feature-icon-wrap">
                        <span class="material-symbols-outlined" aria-hidden="true">more_horiz</span>
                    </div>
                    <div class="feature-text">
                        <strong>I wiele innych form dostępności</strong>
                        <span>Pętle indukcyjne · teksty ETR · i&nbsp;wiele więcej</span>
                    </div>
                </div>

            </div>

            <!-- Separator -->
            <div class="poster-separator">
                <div class="poster-separator-line"></div>
                <div class="poster-separator-gem"></div>
                <div class="poster-separator-line"></div>
            </div>

            <!-- CTA block Z LOGO -->
            <div class="cta-block">

                <div class="cta-qr-wrap" aria-label="Kod QR do DEvents.pl">
                    <div id="general-qr-code"></div>
                </div>

                <div class="cta-text">
                    <p class="cta-text-label">Zeskanuj lub wejdź na</p>
                    <p class="cta-text-url"><span>D</span>Events.pl</p>
                    <p class="cta-text-sub">
                        Bezpłatny portal z&nbsp;kalendarzem dostępnych<br>
                        wydarzeń kulturalnych w całej Polsce
                    </p>
                </div>

                <div class="cta-logo-wrap">
                    <div id="poster-devents-logo-wrapper">
                        <img
                            id="poster-devents-logo"
                            src="{{ home_url }}/wp-content/plugins/wydarzenia/assets/images/logo-DEvents-02.png"
                            alt="DEvents Logo"
                        />
                    </div>
                </div>

            </div>

        </section>

        <!-- BOTTOM BAR -->
        <div class="poster-bottom-bar"></div>

    </div>

    <script>
        window.onload = async function () {

            const loaderText = document.getElementById('loader-text');
            const spinner    = document.getElementById('spinner');

            try {

                /* QR */
                new QRCode(
                    document.getElementById('general-qr-code'),
                    {
                        text:         'https://devents.pl',
                        width:        180,
                        height:       180,
                        colorDark:    '#000000',
                        colorLight:   '#ffffff',
                        correctLevel: QRCode.CorrectLevel.M
                    }
                );

                /* Fonts */
                await document.fonts.ready;

                /* Images */
                await Promise.all(
                    Array.from(document.images).map(img =>
                        img.complete
                            ? Promise.resolve()
                            : new Promise(r => { img.onload = r; img.onerror = r; })
                    )
                );

                /* Small render delay */
                await new Promise(r => setTimeout(r, 350));

                /* PDF */
                const element = document.getElementById('poster-content');
                element.style.boxShadow = 'none';

                await html2pdf()
                    .set({
                        margin:   0,
                        filename: 'DEvents-Plakat-Dostepnosc.pdf',
                        image:    { type: 'jpeg', quality: 1 },
                        html2canvas: {
                            scale:            3,
                            useCORS:          true,
                            letterRendering:  true,
                            backgroundColor:  '#ffffff',
                            onclone: function (clonedDoc) {
                                const b = clonedDoc.body;
                                b.style.display    = 'block';
                                b.style.padding    = '0';
                                b.style.margin     = '0';
                                b.style.minHeight  = 'auto';
                                b.style.background = '#ffffff';
                            }
                        },
                        jsPDF: {
                            unit:        'mm',
                            format:      'a4',
                            orientation: 'portrait'
                        }
                    })
                    .from(element)
                    .save();

                /* Success */
                element.style.boxShadow = '0 10px 40px rgba(0,0,0,.45)';
                spinner.style.display   = 'none';

                loaderText.innerHTML = `
                    <div style="text-align:center;color:#00b09e;">
                        <span class="material-symbols-outlined"
                            style="font-size:54px;margin-bottom:12px;display:block;">
                            check_circle
                        </span>
                        <div style="font-size:28px;font-weight:700;margin-bottom:8px;">
                            Plakat pobrany pomyślnie!
                        </div>
                        <div style="font-size:16px;color:#cfcfcf;font-weight:400;">
                            Możesz bezpiecznie zamknąć tę kartę.
                        </div>
                    </div>`;

            } catch (err) {

                console.error(err);
                spinner.style.display = 'none';

                loaderText.innerHTML = `
                    <div style="text-align:center;color:#ff7b7b;">
                        <span class="material-symbols-outlined"
                            style="font-size:54px;margin-bottom:12px;display:block;">
                            error
                        </span>
                        <div style="font-size:24px;font-weight:700;margin-bottom:8px;">
                            Wystąpił błąd
                        </div>
                        <div style="font-size:16px;color:#d6d6d6;font-weight:400;line-height:1.5;">
                            Nie udało się wygenerować pliku PDF.
                        </div>
                    </div>`;
            }
        };
    </script>

</body>
</html>