{% if followed_events is not empty %}
        {# Siatka kart (Grid) #}
        <div class="cards_grid">
            {% for event in followed_events %}
                {% include 'components/event-card.twig' with {
                    'event': event, 
                    'is_user_logged_in': true,
                    'is_current': event.is_current|default(false)
                } %}
            {% endfor %}
        </div>
    {% else %}
        {# Pusty stan #}
        <div class="message-box message-box--info">
            <span class="material-symbols-outlined" aria-hidden="true">group_off</span>
            <div class="message-content">
                <p>{{ __('Nie obserwujesz jeszcze żadnego organizatora.', 'devents') }}<br>{{ __('Zacznij obserwować, aby widzieć tu ich nowe wydarzenia.', 'devents') }}</p>
                <a href="{{ home_url('/organizatorzy/') }}" class="btn btn--primary btn--small">{{ __('Znajdź organizatorów', 'devents') }}</a>
            </div>
        </div>
    {% endif %}