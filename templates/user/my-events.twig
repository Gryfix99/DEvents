{# templates/user/my-events.twig — v13.0 (i18n ready) #}

{# Konfiguracja statusów z tłumaczeniami #}
{% set status_config = {
    '0': { 'label': __('DO WERYFIKACJI', 'devents'), 'class': 'status-badge--warning' },
    '1': { 'label': __('OPUBLIKOWANE', 'devents'),   'class': 'status-badge--success' },
    '2': { 'label': __('SZKIC', 'devents'),          'class': 'status-badge--neutral' },
    '3': { 'label': __('ODRZUCONE', 'devents'),      'class': 'status-badge--danger' },
    '4': { 'label': __('ODWOŁANE', 'devents'),       'class': 'status-badge--danger' }
} %}

{% macro sort_link(label, key, current_filters, panel_url) %}
    {% set new_order = (current_filters.orderby == key and current_filters.order == 'ASC') ? 'DESC' : 'ASC' %}
    {% set icon = 'unfold_more' %}
    {% if current_filters.orderby == key %}
        {% set icon = current_filters.order == 'ASC' ? 'expand_less' : 'expand_more' %}
    {% endif %}
    
    <a href="{{ panel_url }}?view=moje-wydarzenia&status={{ current_filters.status }}&search={{ current_filters.search }}&category={{ current_filters.category }}&orderby={{ key }}&order={{ new_order }}&per_page={{ current_filters.per_page }}" class="sort-link {{ current_filters.orderby == key ? 'active' : '' }}">
        {{ label }} <span class="material-symbols-outlined" aria-hidden="true">{{ icon }}</span>
    </a>
{% endmacro %}

    <div class="my-content-list__header">
        <a href="{{ panel_url }}?view=dodaj-wydarzenie" class="btn btn--primary">
            <span class="material-symbols-outlined" aria-hidden="true">add_circle</span> {{ __('Opublikuj nowe wydarzenie', 'devents') }}
        </a>
    </div>

    {# --- FILTRY --- #}
    <div class="list-toolbar-wrapper">
        <form action="{{ panel_url }}" method="GET" id="events-filter-form">
            <input type="hidden" name="view" value="moje-wydarzenia">
            <input type="hidden" name="status" value="{{ current_filters.status }}">
            <input type="hidden" name="per_page" value="{{ current_filters.per_page }}">
            <input type="hidden" name="orderby" value="{{ current_filters.orderby }}">
            <input type="hidden" name="order" value="{{ current_filters.order }}">

            <div class="filters-grid">
                <div class="form-group" style="margin:0;">
                    <label class="filters-label">{{ __('Szukaj', 'devents') }}</label>
                    <input type="search" name="search" placeholder="{{ __('Tytuł...', 'devents') }}" value="{{ current_filters.search }}" class="form-control form-input" style="width:100%;">
                </div>

                <div class="form-group" style="margin:0;">
                    <label class="filters-label">{{ __('Kategoria', 'devents') }}</label>
                    <select name="category" class="form-control form-select" style="width:100%;">
                        <option value="">{{ __('Wszystkie', 'devents') }}</option>
                        {% for slug, label in categories %}
                            <option value="{{ slug }}" {{ current_filters.category == slug ? 'selected' : '' }}>{{ label }}</option>
                        {% endfor %}
                    </select>
                </div>

                <div class="form-group" style="margin:0; grid-column: 1 / -1;">
                    <label class="filters-label">{{ __('Dostępność', 'devents') }}</label>
                    {# Kompaktowe ikony-chipy (wielokrotny wybór) — tak jak w wyszukiwarce wydarzeń #}
                    <div class="search-acc-chips">
                        {% for type in accessibility_types %}
                            {% set is_checked = type.id in current_filters.accessibility %}
                            <label class="search-acc-chip {{ is_checked ? 'search-acc-chip--on' : '' }}"
                                   tabindex="0"
                                   role="checkbox"
                                   aria-checked="{{ is_checked ? 'true' : 'false' }}"
                                   onkeydown="if(event.key === 'Enter' || event.key === ' ') { this.click(); event.preventDefault(); }">
                                <input type="checkbox" name="accessibility[]" value="{{ type.id }}" class="sr-only acc-checkbox" {{ is_checked ? 'checked' : '' }}>
                                <span class="material-symbols-outlined" aria-hidden="true">{{ type.icon }}</span>
                                <span class="search-acc-chip__tooltip" aria-hidden="true">{{ type.name }}</span>
                            </label>
                        {% endfor %}
                    </div>
                </div>

                <div class="form-group" style="margin:0;">
                    <label class="filters-label">{{ __('Data od', 'devents') }}</label>
                    <input type="date" name="date_from" value="{{ current_filters.date_from }}" class="form-control" style="width:100%;">
                </div>
                 <div class="form-group" style="margin:0;">
                    <label class="filters-label">{{ __('Data do', 'devents') }}</label>
                    <input type="date" name="date_to" value="{{ current_filters.date_to }}" class="form-control" style="width:100%;">
                </div>
            </div>

            <div class="filters-actions">
                <label style="display:flex; align-items:center; cursor:pointer; gap:8px;">
                    <input type="checkbox" name="featured" value="1" {{ current_filters.featured ? 'checked' : '' }}>
                    <span style="font-size:14px; opacity: 0.9;">{{ __('Tylko wyróżnione', 'devents') }}</span>
                </label>
                
                <div style="display:flex; gap:10px;">
                    <a href="{{ panel_url }}?view=moje-wydarzenia" class="btn btn--secondary btn--small">{{ __('Resetuj', 'devents') }}</a>
                    <button type="submit" class="btn btn--primary btn--small">{{ __('Filtruj', 'devents') }}</button>
                </div>
            </div>
        </form>
    </div>

    {# --- ZAKŁADKI --- #}
    <div class="filter-pills-row" style="margin-bottom: 20px;">
        <div class="filter-pills">
            {% set base_params = '&search=' ~ current_filters.search ~ '&category=' ~ current_filters.category ~ '&per_page=' ~ current_filters.per_page ~ '&orderby=' ~ current_filters.orderby ~ '&order=' ~ current_filters.order %}
            <a href="{{ panel_url }}?view=moje-wydarzenia{{ base_params }}&status=all" class="filter-pill {{ current_filters.status == 'all' ? 'active' : '' }}">{{ __('Wszystkie', 'devents') }}</a>
            <a href="{{ panel_url }}?view=moje-wydarzenia{{ base_params }}&status=published" class="filter-pill {{ current_filters.status == 'published' ? 'active' : '' }}">{{ __('Opublikowane', 'devents') }}</a>
            <a href="{{ panel_url }}?view=moje-wydarzenia{{ base_params }}&status=pending" class="filter-pill {{ current_filters.status == 'pending' ? 'active' : '' }}">{{ __('Do weryfikacji', 'devents') }}</a>
            <a href="{{ panel_url }}?view=moje-wydarzenia{{ base_params }}&status=draft" class="filter-pill {{ current_filters.status == 'draft' ? 'active' : '' }}">{{ __('Szkice', 'devents') }}</a>
            <a href="{{ panel_url }}?view=moje-wydarzenia{{ base_params }}&status=archived" class="filter-pill {{ current_filters.status == 'archived' ? 'active' : '' }}">{{ __('Zakończone', 'devents') }}</a>
            <a href="{{ panel_url }}?view=moje-wydarzenia{{ base_params }}&status=cancelled" class="filter-pill {{ current_filters.status == 'cancelled' ? 'active' : '' }}">{{ __('Odwołane', 'devents') }}</a>
        </div>
    </div>

    {# --- SEKCJA 1: AKTYWNE --- #}
    {% import _self as macros %}
    
    {% if current_filters.status != 'archived' %}
        <div class="section-active">
            <h3 style="margin-bottom:15px; border-left:4px solid var(--primary); padding-left:10px;">{{ __('Wydarzenia Aktualne', 'devents') }}</h3>
            
            {% if active_events is not empty %}
                <div class="table-responsive-wrapper">
                    <table class="my-content-list__table sortable">
                        <thead>
                            <tr>
                                <th>{{ macros.sort_link('ID', 'id', current_filters, panel_url) }}</th>
                                <th>{{ macros.sort_link(__('Tytuł wydarzenia', 'devents'), 'title', current_filters, panel_url) }}</th>
                                <th>{{ macros.sort_link(__('Data rozpoczęcia', 'devents'), 'start_datetime', current_filters, panel_url) }}</th>
                                <th>{{ __('Status', 'devents') }}</th>
                                <th>{{ __('Akcje', 'devents') }}</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for event in active_events %}
                                {% set now_ts = 'now'|date('U') %}
                                {% set start_ts = event.start_datetime|date('U') %}
                                {% set days_left = ((start_ts - now_ts) / 86400)|round(0, 'floor') %}
                                {% set current_status = status_config[event.verified] ?? status_config['2'] %}
                                
                                <tr>
                                    <td data-label="ID">{{ event.id }}</td>
                                    <td data-label="{{ __('Tytuł', 'devents') }}">
                                        <strong>{{ event.title|e }}</strong>
                                        <div style="font-size: 12px; color: #6b7280; margin-top: 4px; display: flex; flex-direction: column; gap: 4px;">
                                            <div style="display: flex; align-items: center; gap: 4px;">
                                                <span class="material-symbols-outlined" style="font-size: 14px;" aria-hidden="true">person</span>
                                                {{ event.creator_first_name|e }} {{ event.creator_last_name|e }}
                                            </div>
                                            {% if is_master %}
                                                <div style="display: flex; align-items: center; gap: 4px;">
                                                    <span class="material-symbols-outlined" style="font-size: 14px;" aria-hidden="true">domain</span>
                                                    {{ event.institution_name|default(__('Nieprzypisana', 'devents'))|e }}
                                                </div>
                                            {% endif %}
                                        </div>
                                    </td>
                                    <td data-label="{{ __('Data', 'devents') }}">{{ event.start_datetime|date('d.m.Y, H:i') }}</td>
                                    <td data-label="{{ __('Status', 'devents') }}"><span class="status-badge {{ current_status.class }}">{{ current_status.label }}</span></td>
                                    <td data-label="{{ __('Akcje', 'devents') }}" class="actions-cell">
                                        <div class="event-card-actions">
                                           <div class="standard-actions-row">
                                                <a href="{{ panel_url }}?view=edytuj-wydarzenie&event_id={{ event.id }}" class="btn btn--secondary btn--small btn--icon" title="{{ __('Edytuj', 'devents') }}" aria-label="{{ __('Edytuj', 'devents') }}"><span class="material-symbols-outlined" aria-hidden="true">edit</span></a>
                                                <button type="button" class="btn btn--secondary btn--small btn--icon js-duplicate-event-btn" title="{{ __('Duplikuj', 'devents') }}" aria-label="{{ __('Duplikuj', 'devents') }}" data-event-id="{{ event.id }}">
                                                    <span class="material-symbols-outlined" aria-hidden="true">content_copy</span>
                                                </button>
                                                {% if event.verified == 4 %}
                                                    <button type="button" class="btn btn--success btn--small btn--icon js-restore-event-btn" title="{{ __('Przywróć (Jako Szkic)', 'devents') }}" aria-label="{{ __('Przywróć (Jako Szkic)', 'devents') }}" data-event-id="{{ event.id }}">
                                                        <span class="material-symbols-outlined" aria-hidden="true">restore</span>
                                                    </button>
                                                {% else %}
                                                    <button type="button" class="btn btn--danger btn--small btn--icon js-cancel-event-btn" title="{{ __('Odwołaj wydarzenie', 'devents') }}" aria-label="{{ __('Odwołaj wydarzenie', 'devents') }}" data-event-id="{{ event.id }}">
                                                        <span class="material-symbols-outlined" aria-hidden="true">block</span>
                                                    </button>
                                                {% endif %}
                                                <button type="button" class="btn btn--secondary btn--small btn--icon js-open-history-modal" title="{{ __('Historia zmian', 'devents') }}" aria-label="{{ __('Historia zmian', 'devents') }}" data-event-id="{{ event.id }}">
                                                    <span class="material-symbols-outlined" aria-hidden="true">manage_search</span>
                                                </button>
                                            </div>

                                            {% if event.verified == 1 %}
                                                <div class="premium-actions-row">
                                                    {% if event.is_featured %}
                                                        <span class="status-badge status-badge--featured" title="{{ __('Wyróżnione do', 'devents') }} {{ event.featured_until }}">
                                                            <span class="material-symbols-outlined" style="font-size:14px; vertical-align:middle;" aria-hidden="true">star</span>
                                                            {{ __('Do', 'devents') }} {{ event.featured_until|date('d-m-Y H:i') }}
                                                        </span>
                                                    {% else %}
                                                        {% if days_left < 3 %}
                                                            <span class="status-badge status-badge--disabled">{{ __('Wyróżnienie niedostępne', 'devents') }}</span>
                                                        {% else %}
                                                            <button type="button" class="btn btn--gold btn--compact js-open-promo-modal" data-event-id="{{ event.id }}" data-days-left="{{ days_left }}" title="{{ __('Wyróżnij (od 15 zł)', 'devents') }}">
                                                                <span class="material-symbols-outlined" aria-hidden="true">verified</span> {{ __('Wyróżnij', 'devents') }}
                                                            </button>
                                                        {% endif %}
                                                    {% endif %}
                                                    
                                                    {% if event.translation_status in ['paid', 'in_progress'] %}
                                                        <span class="status-badge status-badge--warning">{{ __('PJM: W toku', 'devents') }}</span>
                                                    {% elseif event.translation_status == 'completed' %}
                                                        <span class="status-badge status-badge--success">{{ __('PJM: Gotowe', 'devents') }}</span>
                                                    {% else %}
                                                        {% if days_left >= 7 %}
                                                            <button type="button" class="btn btn--blue btn--compact js-open-pjm-modal" data-event-id="{{ event.id }}" title="{{ __('Zamów Tłumaczenie PJM (od 149 zł)', 'devents') }}">
                                                                <span class="material-symbols-outlined" aria-hidden="true">sign_language</span> {{ __('Zamów PJM', 'devents') }}
                                                            </button>
                                                        {% else %}
                                                            <span class="status-badge status-badge--disabled">{{ __('PJM niedostępne', 'devents') }}</span>
                                                        {% endif %}
                                                    {% endif %}
                                                </div>
                                            {% endif %}
                                        </div>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>

                {# Paginacja (Uproszczona dla czytelności) #}
                {% if pagination.total_pages > 1 %}
                     <div class="pagination-container">
                        <div class="per-page-control">
                            <span>{{ __('Pokaż:', 'devents') }}</span>
                            <select onchange="window.location.href=this.value">
                                {% for val in [20, 50, 100, 500] %}
                                    <option value="{{ panel_url }}?view=moje-wydarzenia&per_page={{ val }}&status={{ current_filters.status }}" {{ current_filters.per_page == val ? 'selected' : '' }}>{{ val }}</option>
                                {% endfor %}
                            </select>
                        </div>
                    </div>
                {% endif %}
            {% else %}
                <div class="message-box message-box--info">{{ __('Brak aktywnych wydarzeń pasujących do filtrów.', 'devents') }}</div>
            {% endif %}
        </div>
    {% endif %}

    {# --- SEKCJA 2: ARCHIWUM --- #}
    {% if current_filters.status == 'all' or current_filters.status == 'archived' %}
        <div class="section-archive" style="{{ current_filters.status == 'all' ? 'opacity: 0.8;' : '' }}">
            <h3 style="margin-bottom:15px; border-left:4px solid #666; padding-left:10px; color: #555;">Zakończone Wydarzenia</h3>
            
            {% if archived_events is not empty %}
                <div class="table-responsive-wrapper">
                    <table class="my-content-list__table" style="background: #fdfdfd;">
                        <thead>
                            <tr>
                                <th>{{ macros.sort_link('ID', 'id', current_filters, panel_url) }}</th>
                                <th>{{ macros.sort_link('Tytuł wydarzenia', 'title', current_filters, panel_url) }}</th>
                                <th>{{ macros.sort_link('Data zakończenia', 'end_datetime', current_filters, panel_url) }}</th>
                                <th>Status</th>
                                <th>Akcje</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for event in archived_events %}
                                <tr>
                                    <td data-label="ID" style="color:#888;">{{ event.id }}</td>
                                    <td data-label="Tytuł">
                                        <strong>{{ event.title }}</strong>
                                        <div style="font-size: 12px; color: #6b7280; margin-top: 4px; display: flex; flex-direction: column; gap: 4px;">
                                            
                                            {# Wiersz 1: Twórca #}
                                            <div style="display: flex; align-items: center; gap: 4px;">
                                                <span class="material-symbols-outlined" style="font-size: 14px;" aria-hidden="true">person</span>
                                                {{ event.creator_first_name }} {{ event.creator_last_name }}
                                            </div>

                                            {# Wiersz 2: Instytucja (tylko dla Mastera) #}
                                            {% if is_master %}
                                                <div style="display: flex; align-items: center; gap: 4px;">
                                                    <span class="material-symbols-outlined" style="font-size: 14px;" aria-hidden="true">domain</span>
                                                    {{ event.institution_name ?: 'Nieprzypisana' }}
                                                </div>
                                            {% endif %}
                                        </div>
                                    </td>
                                    <td data-label="Data" style="color:#666;">{{ event.end_datetime|date('d.m.Y, H:i') }}</td>
                                    <td data-label="Status"><span class="status-badge status-badge--neutral">Zakończone</span></td>
                                    <td data-label="Akcje">
                                        <div class="standard-actions-row">
                                            <div class="standard-actions-row">
                                                <button type="button" class="btn btn--secondary btn-icon-only js-duplicate-event-btn" title="Wystaw ponownie (Duplikuj)" aria-label="Wystaw ponownie (Duplikuj)" data-event-id="{{ event.id }}">
                                                    <span class="material-symbols-outlined" aria-hidden="true">restart_alt</span>
                                                </button>
                                            </div>
                                        </div>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>

                {% if current_filters.status == 'all' %}
                    <div style="text-align:center; margin-top:15px;">
                        <a href="{{ panel_url }}?view=moje-wydarzenia&status=archived" class="btn btn--secondary">Zobacz całe archiwum &rsaquo;</a>
                    </div>
                {% endif %}

                {% if current_filters.status == 'archived' and pagination.total_pages > 1 %}
                    <div class="pagination-container" style="display: flex; justify-content: flex-end; align-items: center; gap: 20px; margin-top: 20px; padding: 15px; background: #eee; border-radius: 8px;">
                         <div class="pagination-links" style="display: flex; gap: 5px;">
                            {% if pagination.current > 1 %}
                                <a href="{{ panel_url }}?view=moje-wydarzenia&status=archived&paged={{ pagination.current - 1 }}" class="btn btn--secondary btn--small">&laquo;</a>
                            {% endif %}
                            {% for i in 1..pagination.total_pages %}
                                {% if i == pagination.current %}
                                    <span class="btn btn--primary btn--small disabled">{{ i }}</span>
                                {% elseif i < 3 or i > pagination.total_pages - 2 or (i >= pagination.current - 2 and i <= pagination.current + 2) %}
                                    <a href="{{ panel_url }}?view=moje-wydarzenia&status=archived&paged={{ i }}" class="btn btn--secondary btn--small">{{ i }}</a>
                                {% elseif i == 3 or i == pagination.total_pages - 2 %}
                                    <span class="pagination-dots">...</span>
                                {% endif %}
                            {% endfor %}
                            {% if pagination.current < pagination.total_pages %}
                                <a href="{{ panel_url }}?view=moje-wydarzenia&status=archived&paged={{ pagination.current + 1 }}" class="btn btn--secondary btn--small">&raquo;</a>
                            {% endif %}
                        </div>
                    </div>
                {% endif %}
            {% else %}
                 <div class="message-box" style="margin-top:10px;">Brak archiwalnych wydarzeń.</div>
            {% endif %}
        </div>
    {% endif %}


{# --- MODALE --- #}
<style>
.payment-mode{border:1px solid var(--border-primary,#e5e7eb);border-radius:var(--border-radius-medium,10px);padding:14px 16px;margin-top:18px;display:flex;flex-direction:column;gap:10px;background:var(--bg-secondary,#f8fafc)}
.payment-mode__legend{font-weight:700;font-size:.95rem;padding:0 4px}
.payment-mode__option{display:flex;align-items:flex-start;gap:10px;font-size:.92rem;cursor:pointer;line-height:1.4}
.payment-mode__option input{margin-top:3px;flex:0 0 auto;width:18px;height:18px}
.pay-method{display:inline-block;margin-top:6px;font-weight:600;color:var(--primary,#00857c)}
</style>
{# === MODAL 1: PROMOWANIE (3 ETAPY) === #}
<div id="promo-modal" class="graphic-modal-overlay hidden" role="dialog" aria-modal="true" aria-labelledby="promo-modal-title">
    <div class="graphic-modal-content pjm-modal-wide">
        <button type="button" class="graphic-modal-close" aria-label="{{ __('Zamknij', 'devents') }}"><span aria-hidden="true">&times;</span></button>

        <div class="pjm-steps">
            <div class="step active" data-step="1">1. Wybór pakietu</div>
            <div class="step" data-step="2">2. Dane i Faktura</div>
            <div class="step" data-step="3">3. Podsumowanie</div>
        </div>

        <form id="promo-form">
            <input type="hidden" name="event_id" id="promo-event-id">
            <input type="hidden" name="action" value="devents_create_promo_order">
            <input type="hidden" name="coupon_code" id="promo-coupon-code-hidden">

            {# ETAP 1: Wybór (Radio) #}
            <div class="step-content active" id="promo-step-1">
                <div class="scrollable-content">
                    <h3 id="promo-modal-title" style="text-align:center; margin-bottom:20px;">Wybierz okres wyróżnienia</h3>
                    <div class="promo-options-grid">
                        {# Karta 3 dni #}
                        <label class="promo-option-wrapper">
                            <input type="radio" name="promo_package" value="featured_3_days" class="promo-radio-input" data-price="15">
                            <div class="promo-option-card">
                                <div class="card-content">
                                    <span class="days-large">3</span>
                                    <span class="days-label">dni</span>
                                    <div class="price-tag">15 zł</div>
                                </div>
                                <div class="promo-error hidden">Za późno</div>
                            </div>
                        </label>

                        {# Karta 7 dni #}
                        <label class="promo-option-wrapper">
                            <input type="radio" name="promo_package" value="featured_7_days" class="promo-radio-input" data-price="29">
                            <div class="promo-option-card">
                                <div class="card-content">
                                    <span class="days-large">7</span>
                                    <span class="days-label">dni</span>
                                    <div class="price-tag">29 zł</div>
                                </div>
                                <div class="promo-error hidden">Za późno</div>
                            </div>
                        </label>

                        {# Karta 14 dni #}
                        <label class="promo-option-wrapper">
                            <input type="radio" name="promo_package" value="featured_14_days" class="promo-radio-input" data-price="49">
                            <div class="promo-option-card card-featured">
                                <div class="best-value-badge">Polecane</div>
                                <div class="card-content">
                                    <span class="days-large">14</span>
                                    <span class="days-label">dni</span>
                                    <div class="price-tag">49 zł</div>
                                </div>
                                <div class="promo-error hidden">Za późno</div>
                            </div>
                        </label>
                    </div>
                </div>
                <div class="wizard-footer">
                    <button type="button" class="btn btn--primary btn-next" data-next="2" disabled id="btn-promo-next-1">Dalej: Dane &rsaquo;</button>
                </div>
            </div>

            {# ETAP 2: Dane i Faktura #}
            <div class="step-content" id="promo-step-2">
                {% include 'components/order-billing-form.twig' %}
                <div class="wizard-footer">
                    <button type="button" class="btn btn--secondary btn-prev" data-prev="1">&lsaquo; Wróć</button>
                    <button type="button" class="btn btn--primary btn-next" data-next="3">Podsumowanie &rsaquo;</button>
                </div>
            </div>

            {# ETAP 3: Podsumowanie #}
