                                        </tfoot>
                                    </table>
                                     <div class="discount-section">
                                        <div class="discount-input-group">
                                            <input type="text" id="pjm-coupon-input" class="form-control" placeholder="Kod rabatowy" aria-label="Kod rabatowy">
                                            <button type="button" class="btn btn--secondary btn--small" id="btn-apply-pjm-coupon">Użyj</button>
                                        </div>
                                        <div id="pjm-coupon-message"></div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="wizard-footer centered-footer">
