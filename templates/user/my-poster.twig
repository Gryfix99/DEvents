<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>Plakat Dostępności - {{ inst_name }}</title>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <link
        href="https://fonts.googleapis.com/css2?family=Dosis:wght@400;500;600;700;800&display=swap"
        rel="stylesheet"
    />

    <!-- Material Symbols -->
    <link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,1,0"
    />

    <!-- PDF -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>

    <!-- QR -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>

    <style>
        :root{
            --bg:#2b2d30;

            --p:#00857C;
            --pd:#00332f;
            --p2:#f8b334;

            --a:#956F28;
            --a2:#c49035;

            --s:#1a1a1c;

            --white:#ffffff;

            --radius-xl:8mm;
            --radius-lg:5mm;
            --radius-md:3mm;

            --shadow-xl:0 10px 40px rgba(0,0,0,.45);

            --safe-padding-x:12mm;
        }

        *,
        *::before,
        *::after{
            box-sizing:border-box;
        }

        html,
        body{
            margin:0;
            padding:0;

            min-height:100vh;

            background:var(--bg);

            display:flex;
            align-items:center;
            justify-content:center;

            font-family:'Dosis',sans-serif;

            overflow-x:hidden;

            text-rendering:optimizeLegibility;

            -webkit-font-smoothing:antialiased;
            -moz-osx-font-smoothing:grayscale;
        }

        body{
            padding:20px;
        }

        /* =========================
           LOADER
        ========================== */

        #pdf-loader{
            position:fixed;
            inset:0;

            z-index:99999;

            background:rgba(43,45,48,.96);

            display:flex;
            flex-direction:column;
            align-items:center;
            justify-content:center;

            color:#fff;
        }

        .spinner{
            width:58px;
            height:58px;

            border-radius:50%;

            border:5px solid rgba(255,255,255,.12);
            border-top-color:var(--p2);

            animation:spin 1s linear infinite;

            margin-bottom:24px;
        }

        @keyframes spin{
            to{
                transform:rotate(360deg);
            }
        }

        #loader-text{
            font-size:24px;
            font-weight:700;
            letter-spacing:.3px;
            text-align:center;
        }

        /* =========================
           POSTER
        ========================== */

        #poster-content{
            width:210mm;
            height:296.5mm;

            position:relative;

            overflow:hidden;

            display:flex;
            flex-direction:column;

            background:#fff;
            color:var(--s);

            isolation:isolate;
            contain:layout;

            box-shadow:var(--shadow-xl);
        }

        .poster-top-bar{
            height:4mm;

            flex-shrink:0;

            background:
                linear-gradient(
                    90deg,
                    var(--pd),
                    var(--p),
                    var(--a2)
                );
        }

        /* =========================
           HERO
        ========================== */

        .poster-hero{
            position:relative;

            display:flex;
            flex-direction:column;
            justify-content:space-between;

            min-height:88mm;

            padding:
                8mm
                var(--safe-padding-x)
                7mm;

            background:
                linear-gradient(
                    135deg,
                    var(--pd) 0%,
                    #004d47 100%
                );

            overflow:hidden;

            flex-shrink:0;
        }

        .poster-deco-bg-d{
            position:absolute;

            top:-20mm;
            right:-8mm;

            font-size:210pt;
            font-weight:800;

            line-height:1;

            color:rgba(255,255,255,.03);

            pointer-events:none;

            user-select:none;
        }

        .poster-deco-ring{
            position:absolute;

            width:54mm;
            height:54mm;

            top:-16mm;
            left:42mm;

            border-radius:50%;

            border:8mm solid rgba(0,176,158,.08);
        }

        .hero-top-flex{
            position:relative;
            z-index:2;

            display:flex;
            justify-content:space-between;
            align-items:flex-start;
            gap:8mm;
        }

        .poster-headline-top{
            margin:0;

            max-width:72%;

            font-size:40pt;
            line-height:.92;
            letter-spacing:-1.2px;
            font-weight:800;

            color:#fff;

            text-transform:uppercase;

            text-wrap:balance;

            overflow-wrap:anywhere;

            text-shadow:0 4px 10px rgba(0,0,0,.28);
        }

        .poster-headline-top span{
            display:block;
            color:var(--p2);
        }

        /* =========================
           LOGO
        ========================== */

        .inst-logo-circle{
            width:36mm;
            height:36mm;

            flex-shrink:0;

            border-radius:50%;

            background:#fff;

            overflow:hidden;

            display:flex;
            align-items:center;
            justify-content:center;

            padding:4.5mm;

            box-shadow:
                0 0 0 2mm rgba(255,255,255,.08),
                0 8px 20px rgba(0,0,0,.35);
        }

        .inst-logo-circle img{
            max-width:100%;
            max-height:100%;

            width:auto;
            height:auto;

            object-fit:contain;
            object-position:center;

            display:block;
        }

        /* =========================
           BADGE
        ========================== */

        .poster-hero-badge{
            position:relative;
            z-index:2;

            margin-top:auto;
            margin-bottom:3mm;

            width:fit-content;

            display:inline-flex;
            align-items:center;
            gap:2mm;

            padding:1.7mm 3.4mm;

            border-radius:999px;

            background:rgba(255,255,255,.08);

            backdrop-filter:blur(4px);

            color:#fff;

            font-size:8pt;
            font-weight:700;

            letter-spacing:.5px;
        }

        .poster-hero-badge-dot{
            width:2mm;
            height:2mm;

            border-radius:50%;

            background:var(--p2);

            box-shadow:0 0 10px rgba(0,176,158,.7);
        }

        /* =========================
           ACCESSIBILITY STRIP (hero)
        ========================== */

        .poster-access-strip{
            position:relative;
            z-index:2;

            display:flex;
            align-items:center;
            flex-wrap:wrap;

            margin-top:4mm;
        }

        .poster-access-icon{
            width:12mm;
            height:12mm;

            flex-shrink:0;

            border-radius:50%;

            display:flex;
            align-items:center;
            justify-content:center;

            background:rgba(255,255,255,.10);

            border:.3mm solid rgba(255,255,255,.16);

            box-shadow:0 4px 10px rgba(0,0,0,.15);
        }

        .poster-access-icon .material-symbols-outlined{
            font-size:16pt !important;
            color:#fff;
        }

        .poster-access-connector{
            width:3mm;
            height:.5mm;

            background:rgba(255,255,255,.18);
        }

        .poster-access-tagline{
            margin-left:5mm;

            font-size:7.5pt;
            font-weight:700;

            letter-spacing:1.6px;
            text-transform:uppercase;

            color:rgba(255,255,255,.55);
        }

        /* =========================
           WAVE
        ========================== */

        .poster-wave{
            position:relative;

            height:12mm;

            margin-top:-1px;

            background:#fff;
        }

        .poster-wave svg{
            display:block;

            width:100%;
            height:100%;
        }

        /* =========================
           LOWER SECTION
        ========================== */

        .poster-lower{
            position:relative;

            flex:1 1 auto;

            min-height:0;

            display:flex;
            flex-direction:column;

            padding:
                8mm
                var(--safe-padding-x)
                5mm;

            background:
                linear-gradient(
                    to bottom,
                    rgba(255,255,255,1),
                    rgba(250,250,250,1)
                );
        }

        .poster-lower-dots{
            position:absolute;
            inset:0;

            pointer-events:none;

            background-image:
                radial-gradient(
                    circle,
                    rgba(0,0,0,.03) 1px,
                    transparent 1px
                );

            background-size:6mm 6mm;
        }

        .poster-inst-headline{
            position:relative;
            z-index:1;

            flex-shrink:0;

            margin:0;

            font-size:clamp(14pt, 3.2vw, 32pt);

            font-weight:800;
            line-height:1.05;
            letter-spacing:-.5px;

            color:var(--s);

            overflow-wrap:anywhere;
            word-break:break-word;
            hyphens:auto;

            text-wrap:balance;

            max-width:100%;
        }

        .poster-tagline{
            position:relative;
            z-index:1;

            flex-shrink:0;

            margin:
                1.5mm
                0
                2mm;

            font-size:16pt;
            line-height:1.15;

            font-weight:600;

            color:var(--a);

            text-wrap:balance;
        }

        /* =========================
           SEPARATOR
        ========================== */

        .poster-separator{
            position:relative;
            z-index:1;

            flex-shrink:0;

            display:flex;
            align-items:center;
            gap:3mm;

            margin:2mm 0;
        }

        .poster-separator-line{
            flex:1;

            height:.5mm;

            background:
                linear-gradient(
                    90deg,
                    transparent,
                    #dcdcdc,
                    transparent
                );
        }

        .poster-separator-gem{
            width:5mm;
            height:5mm;

            flex-shrink:0;

            border-radius:1mm;

            transform:rotate(45deg);

            background:
                linear-gradient(
                    135deg,
                    var(--p),
                    var(--a)
                );

            box-shadow:0 0 10px rgba(149,111,40,.3);
        }

        /* =========================
           CTA
        ========================== */

        .poster-cta{
            position:relative;
            z-index:1;

            flex:1 1 auto;

            min-height:0;

            display:flex;
            flex-direction:column;
            align-items:center;
            justify-content:center;

            text-align:center;

            padding:2mm 0;

            overflow:hidden;
        }

        /* =========================
           CTA — KROKI
        ========================== */

        .poster-steps{
            display:flex;
            align-items:flex-start;
            justify-content:center;

            width:100%;

            margin-bottom:3mm;
        }

        .poster-step{
            flex:1;

            display:flex;
            flex-direction:column;
            align-items:center;

            text-align:center;
        }

        .poster-step-num{
            width:7mm;
            height:7mm;

            border-radius:50%;

            background:var(--pd);
            color:#fff;

            font-size:12pt;
            font-weight:800;
            line-height:1;

            display:flex;
            align-items:center;
            justify-content:center;

            margin-bottom:2mm;
        }

        .poster-step .material-symbols-outlined{
            font-size:17pt !important;
            color:var(--p);

            display:block;

            margin-bottom:1.5mm;
        }

        .poster-step-txt{
            font-size:8.5pt;
            font-weight:700;

            color:var(--s);

            line-height:1.35;
        }

        .poster-step-line{
            width:8mm;
            height:.5mm;

            background:#dcdcdc;

            flex-shrink:0;

            margin-top:3.5mm;
        }

        /* =========================
           CTA — URL BOX
        ========================== */

        .poster-url-box{
            border:.8mm solid var(--p);
            border-radius:var(--radius-md);

            padding:3mm 8mm;

            text-align:center;

            background:rgba(0,133,124,.04);

            width:100%;
        }

        .poster-url-hint{
            font-size:8pt;
            font-weight:700;

            text-transform:uppercase;
            letter-spacing:1.5px;

            color:var(--p);

            margin-bottom:1mm;
        }

        .poster-url{
            font-size:clamp(24pt, 5vw, 34pt);

            font-weight:800;
            line-height:1;

            margin:0;

            overflow-wrap:anywhere;

            text-wrap:balance;

            color:var(--s);
        }

        .poster-url span{
            color:var(--p);

            font-size:1.3em;
        }

        /* =========================
           FOOTER
        ========================== */

        .poster-footer{
            position:relative;
            z-index:1;

            flex-shrink:0;

            display:flex;
            justify-content:space-between;
            align-items:flex-end;
            gap:8mm;

            padding-top:4mm;

            border-top:.5mm solid #ececec;
        }

        .footer-left{
            display:flex;
            align-items:center;
            gap:5mm;
        }

        .poster-qr-frame{
            width:28mm;
            height:28mm;

            flex-shrink:0;

            padding:1.2mm;

            border:1mm solid var(--p);
            border-radius:2mm;

            background:#fff;

            display:flex;
            align-items:center;
            justify-content:center;

            box-shadow:0 4px 10px rgba(0,0,0,.05);
        }

        #local-qr-code{
            width:100%;
            height:100%;
        }

        #local-qr-code canvas,
        #local-qr-code img{
            width:100% !important;
            height:100% !important;

            display:block;
        }

        .poster-qr-caption{
            font-size:7.5pt;
            line-height:1.4;

            font-weight:700;

            text-transform:uppercase;

            color:#777;
        }

        .footer-right{
            display:flex;
            align-items:flex-end;
            justify-content:flex-end;
        }

        #poster-devents-logo{
            height:11mm;

            object-fit:contain;

            display:block;
        }

        /* =========================
           BOTTOM BAR
        ========================== */

        .poster-bottom-bar{
            height:4mm;

            flex-shrink:0;

            background:
                linear-gradient(
                    90deg,
                    var(--a),
                    var(--p)
                );
        }

        /* =========================
           PRINT
        ========================== */

        @media print{

            html,
            body{
                background:#fff;
            }

            #poster-content{
                box-shadow:none !important;
            }

            *{
                -webkit-print-color-adjust:exact !important;
                print-color-adjust:exact !important;
            }
        }
    </style>
</head>

<body>

    <!-- =========================
         LOADER
    ========================== -->

    <div id="pdf-loader">
        <div class="spinner" id="spinner"></div>

        <div id="loader-text">
            Generowanie doskonałego pliku PDF...
        </div>
    </div>

    <!-- =========================
         POSTER
    ========================== -->

    <div id="poster-content">

        <!-- TOP BAR -->
        <div class="poster-top-bar"></div>

        <!-- HERO -->
        <section class="poster-hero">

            <div class="poster-deco-bg-d">D</div>
            <div class="poster-deco-ring"></div>

            <div class="hero-top-flex">

                <h1 class="poster-headline-top">
                    Tworzymy<br>
                    <span>dostępne</span>
                    wydarzenia
                </h1>

                <div class="inst-logo-circle">

                    {% if logo_url %}

                        <img
                            src="{{ logo_url }}"
                            alt="Logo {{ inst_name }}"
                            crossorigin="anonymous"
                        />

                    {% else %}

                        <span class="material-symbols-outlined inst-logo-placeholder">
                            domain
                        </span>

                    {% endif %}

                </div>

            </div>

            <!-- BADGE -->
            <div class="poster-hero-badge">

                <span class="poster-hero-badge-dot"></span>

                <span>
                    Instytucja dostępna · DEvents
                </span>

            </div>

            <!-- ACCESSIBILITY STRIP (hero) -->
            <div class="poster-access-strip">

                <div class="poster-access-icon">
                    <span class="material-symbols-outlined">
                        accessible
                    </span>
                </div>

                <div class="poster-access-connector"></div>

                <div class="poster-access-icon">
                    <span class="material-symbols-outlined">
                        hearing
                    </span>
                </div>

                <div class="poster-access-connector"></div>

                <div class="poster-access-icon">
                    <span class="material-symbols-outlined">
                        visibility
                    </span>
                </div>

                <div class="poster-access-connector"></div>

                <div class="poster-access-icon">
                    <span class="material-symbols-outlined">
                        sign_language
                    </span>
                </div>

                <div class="poster-access-connector"></div>

                <div class="poster-access-icon">
                    <span class="material-symbols-outlined">
                        closed_caption
                    </span>
                </div>

                <span class="poster-access-tagline">
                    Standard Dostępności
                </span>

            </div>

        </section>

        <!-- WAVE -->
        <div class="poster-wave">

            <svg
                viewBox="0 0 1000 100"
                preserveAspectRatio="none"
            >
                <path
                    d="M0 0 H1000 V50 Q800 100 600 70 Q400 40 200 80 Q100 90 0 70 Z"
                    fill="#004d47"
                />
            </svg>

        </div>

        <!-- LOWER -->
        <section class="poster-lower">

            <div class="poster-lower-dots"></div>

            <h2 class="poster-inst-headline">
                {{ inst_name }}
            </h2>

            <p class="poster-tagline">
                Otwarci dla każdego, bez wyjątku!
            </p>

            <!-- SEPARATOR -->
            <div class="poster-separator">

                <div class="poster-separator-line"></div>

                <div class="poster-separator-gem"></div>

                <div class="poster-separator-line"></div>

            </div>

            <!-- CTA -->
            <div class="poster-cta">

                <!-- Kroki -->
                <div class="poster-steps">

                    <div class="poster-step">
                        <div class="poster-step-num">1</div>
                        <span class="material-symbols-outlined" aria-hidden="true">
                            qr_code_scanner
                        </span>
                        <div class="poster-step-txt">
                            Zeskanuj<br>kod QR
                        </div>
                    </div>

                    <div class="poster-step-line"></div>

                    <div class="poster-step">
                        <div class="poster-step-num">2</div>
                        <span class="material-symbols-outlined" aria-hidden="true">
                            search
                        </span>
                        <div class="poster-step-txt">
                            Wybierz<br>wydarzenie
                        </div>
                    </div>

                    <div class="poster-step-line"></div>

                    <div class="poster-step">
                        <div class="poster-step-num">3</div>
                        <span class="material-symbols-outlined" aria-hidden="true">
                            verified
                        </span>
                        <div class="poster-step-txt">
                            Sprawdź<br>dostępność
                        </div>
                    </div>

                </div>

                <!-- URL -->
                <div class="poster-url-box">

                    <div class="poster-url-hint">
                        lub wejdź bezpośrednio na
                    </div>

                    <div class="poster-url">
                        <span>D</span>Events.pl
                    </div>

                </div>

            </div>

            <!-- FOOTER -->
            <footer class="poster-footer">

                <div class="footer-left">

                    <div class="poster-qr-frame">
                        <div id="local-qr-code"></div>
                    </div>

                    <div class="poster-qr-caption">
                        Zeskanuj kod QR,<br>
                        aby sprawdzić kalendarz
                    </div>

                </div>

                <div class="footer-right">

                    <img
                        id="poster-devents-logo"
                        src="{{ home_url() }}/wp-content/plugins/wydarzenia/assets/images/logo-DEvents_light-mode.png"
                        alt="DEvents Logo"
                        crossorigin="anonymous"
                    />

                </div>

            </footer>

        </section>

        <!-- BOTTOM BAR -->
        <div class="poster-bottom-bar"></div>

    </div>

    <!-- =========================
         SCRIPT
    ========================== -->

    <script>
        window.onload = async function () {

            const loaderText = document.getElementById('loader-text');
            const spinner    = document.getElementById('spinner');

            try {

                /* =========================
                   GENERATE QR
                ========================== */

                new QRCode(
                    document.getElementById('local-qr-code'),
                    {
                        text: "{{ profile_url }}",

                        width: 150,
                        height: 150,

                        colorDark:  "#000000",
                        colorLight: "#ffffff",

                        correctLevel: QRCode.CorrectLevel.M
                    }
                );

                /* =========================
                   WAIT FOR FONTS
                ========================== */

                await document.fonts.ready;

                /* =========================
                   WAIT FOR IMAGES
                ========================== */

                const images = Array.from(document.images);

                await Promise.all(
                    images.map((img) => {

                        if (img.complete) {
                            return Promise.resolve();
                        }

                        return new Promise((resolve) => {
                            img.onload  = resolve;
                            img.onerror = resolve;
                        });

                    })
                );

                /* =========================
                   SMALL RENDER DELAY
                ========================== */

                await new Promise(resolve => setTimeout(resolve, 300));

                /* =========================
                   GENERATE PDF
                ========================== */

                const element = document.getElementById('poster-content');

                element.style.boxShadow = 'none';

                const opt = {

                    margin: 0,

                    filename: 'Plakat-Dostepnosci-DEvents.pdf',

                    image: {
                        type:    'jpeg',
                        quality: 1
                    },

                    html2canvas: {

                        scale: 3,

                        useCORS: true,

                        letterRendering: true,

                        backgroundColor: '#ffffff',

                        onclone: function (clonedDoc) {
                            const b = clonedDoc.body;
                            b.style.display    = 'block';
                            b.style.padding    = '0';
                            b.style.margin     = '0';
                            b.style.minHeight  = 'auto';
                            b.style.background = '#ffffff';
                        }
                    },

                    jsPDF: {

                        unit:        'mm',

                        format:      'a4',

                        orientation: 'portrait'
                    }
                };

                await html2pdf()
                    .set(opt)
                    .from(element)
                    .save();

                /* =========================
                   SUCCESS
                ========================== */

                element.style.boxShadow = '0 10px 40px rgba(0,0,0,.45)';

                spinner.style.display = 'none';

                loaderText.innerHTML = `
                    <div style="text-align:center; color:#00b09e;">

                        <span
                            class="material-symbols-outlined"
                            style="
                                font-size:54px;
                                margin-bottom:12px;
                                display:block;
                            "
                        >
                            check_circle
                        </span>

                        <div
                            style="
                                font-size:28px;
                                font-weight:700;
                                margin-bottom:8px;
                            "
                        >
                            Plakat pobrany pomyślnie!
                        </div>

                        <div
                            style="
                                font-size:16px;
                                color:#cfcfcf;
                                font-weight:400;
                            "
                        >
                            Możesz bezpiecznie zamknąć tę kartę.
                        </div>

                    </div>
                `;

            } catch (error) {

                console.error(error);

                spinner.style.display = 'none';

                loaderText.innerHTML = `
                    <div style="text-align:center; color:#ff7b7b;">

                        <span
                            class="material-symbols-outlined"
                            style="
                                font-size:54px;
                                margin-bottom:12px;
                                display:block;
                            "
                        >
                            error
                        </span>

                        <div
                            style="
