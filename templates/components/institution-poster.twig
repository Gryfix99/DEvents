{# templates/components/institution-poster.twig — plakat instytucji (html2canvas) #}
<div data-inst-poster
     style="position:relative; width:1080px; height:1350px; background:linear-gradient(135deg,#0f172a 0%,#1e293b 60%,#00857c 140%); color:#ffffff; font-family:'Montserrat','Dosis',sans-serif; overflow:hidden;">
    <div style="position:absolute; inset:0; padding:90px; display:flex; flex-direction:column; justify-content:space-between; box-sizing:border-box;">

        {# Góra: logo + typ #}
        <div style="display:flex; align-items:center; gap:32px;">
            {% if inst.logo_url %}
                <img src="{{ inst.logo_url|e }}" alt="" crossorigin="anonymous"
                     style="width:170px; height:170px; object-fit:contain; background:#ffffff; border-radius:28px; padding:18px; box-sizing:border-box;">
            {% endif %}
            <div style="font-size:30px; letter-spacing:3px; text-transform:uppercase; opacity:.85; font-weight:700;">
                {{ inst.type == 'master' ? 'Instytucja nadrzędna' : 'Organizator wydarzeń' }}
            </div>
        </div>

        {# Środek: nazwa + dane kontaktowe #}
        <div>
            <h1 style="font-size:90px; line-height:1.05; margin:0 0 48px; font-weight:800;">{{ inst.name|e }}</h1>
            <div style="font-size:38px; line-height:1.7; opacity:.95;">
                {% if inst.address %}<div style="display:flex; gap:20px; align-items:flex-start;"><span style="opacity:.8;">📍</span><span>{{ inst.address|e }}</span></div>{% endif %}
                {% if inst.email %}<div style="display:flex; gap:20px; align-items:center;"><span style="opacity:.8;">✉️</span><span>{{ inst.email|e }}</span></div>{% endif %}
                {% if inst.phone %}<div style="display:flex; gap:20px; align-items:center;"><span style="opacity:.8;">📞</span><span>{{ inst.phone|e }}</span></div>{% endif %}
                {% if inst.website %}<div style="display:flex; gap:20px; align-items:center;"><span style="opacity:.8;">🌐</span><span>{{ inst.website|e }}</span></div>{% endif %}
            </div>
        </div>

        {# Dół: CTA + logo systemu #}
        <div style="display:flex; align-items:center; justify-content:space-between; border-top:3px solid rgba(255,255,255,.22); padding-top:46px;">
            <span style="font-size:36px; font-weight:800; max-width:640px; line-height:1.2;">Zapraszamy na nasze dostępne wydarzenia</span>
            <img src="{{ logo_url|e }}" alt="DEvents" crossorigin="anonymous" style="height:70px;">
        </div>
    </div>
</div>
