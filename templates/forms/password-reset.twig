{# templates/pages/password-reset.twig — v13.0 (i18n ready) #}
<div class="auth-container">
    <div class="auth-card">
        <div id="form-message" style="display: none;" class="auth-message"></div>

        {# ETAP 1: Podaj e-mail #}
        <div id="reset-step-1">
            <div class="auth-header">
                <h2 class="auth-title">{{ __('Zresetuj hasło', 'devents') }}</h2>
            </div>
            <p class="auth-info-text">
                {{ __('Podaj swój adres e-mail, aby otrzymać 6-cyfrowy kod weryfikacyjny.', 'devents') }}
            </p>
            <form id="send-code-form" class="devents-form">
                <div class="form-group">
                    <label for="user_email" class="form-label">{{ __('Adres e-mail', 'devents') }}</label>
                    <input type="email" id="user_email" name="user_email" class="form-control" required>
                </div>
                <div class="form-group">
                    <button type="submit" class="btn btn--primary btn--full-width">
                        {{ __('Wyślij kod', 'devents') }}
                    </button>
                </div>
            </form>
        </div>

        {# ETAP 2: Wpisz kod weryfikacyjny #}
        <div id="reset-step-2" style="display: none;">
            <div class="auth-header">
                <h2 class="auth-title">{{ __('Wpisz kod weryfikacyjny', 'devents') }}</h2>
            </div>
            <p class="auth-info-text">
                {{ __('Kod został wysłany na adres %s.', 'devents')|replace({'%s': '<strong id="user-email-display"></strong>'})|raw }}
            </p>
            <form id="validate-code-form" class="devents-form" autocomplete="off" novalidate>
                
                <div class="code-inputs">
                    {% for i in 1..6 %}
                        <input type="text"
                            inputmode="numeric"
                            pattern="[0-9]*"
                            maxlength="1"
                            class="form-control code-digit"
                            id="reset_code_{{ i }}"
                            name="reset_code_{{ i }}"
                            required
                            aria-label="{{ __('Cyfra kodu %s', 'devents')|format(i) }}"
                            autocomplete="off">
                    {% endfor %}
                </div>
                
                <div class="form-group" style="margin-top: 1rem;">
                    <button type="submit" class="btn btn--primary btn--full-width">
                        {{ __('Zweryfikuj kod', 'devents') }}
                    </button>
                </div>
            </form>
        </div>

        {# ETAP 3: Ustaw nowe hasło #}
        <div id="reset-step-3" style="display: none;">
            <div class="auth-header">
                <h2 class="auth-title">{{ __('Ustaw nowe hasło', 'devents') }}</h2>
            </div>
            <form id="set-password-form" class="devents-form" autocomplete="off">
                <input type="text" name="username" id="username-field" autocomplete="username" value="" style="position: absolute; left: -9999px;" aria-hidden="true" tabindex="-1">
                <input type="hidden" name="set_pass_reset_code" id="set_pass_reset_code">
                
                <div class="form-group">
                    <label for="pass1" class="form-label">{{ __('Nowe hasło', 'devents') }}</label>
                    <input type="password" name="pass1" id="pass1" class="form-control" autocomplete="new-password" required>
                </div>
                
                <div class="password-strength-wrapper form-group">
                    <meter max="4" id="password-strength-meter"></meter>
                    <p id="password-strength-text" class="form-input-info"></p>
                    <ul id="password-requirements" class="password-requirements-list">
                        <li id="length">{{ __('Minimum 8 znaków', 'devents') }}</li>
                        <li id="uppercase">{{ __('Jedna duża litera', 'devents') }}</li>
                        <li id="lowercase">{{ __('Jedna mała litera', 'devents') }}</li>
                        <li id="digit">{{ __('Jedna cyfra', 'devents') }}</li>
                    </ul>
                </div>
                <div class="form-group">
                    <label for="pass2" class="form-label">{{ __('Potwierdź nowe hasło', 'devents') }}</label>
                    <input type="password" name="pass2" id="pass2" class="form-control" autocomplete="new-password" required>
                </div>
                <div class="form-group">
                    <button type="submit" class="btn btn--primary btn--full-width">
                        {{ __('Zapisz nowe hasło', 'devents') }}
                    </button>
                </div>
            </form>
        </div>

    </div>
</div>